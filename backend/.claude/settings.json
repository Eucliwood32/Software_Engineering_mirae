{
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(pytest *)",
      "Bash(python -m coverage *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(pip install *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd $CLAUDE_PROJECT_DIR && ruff check src/ --fix --exit-non-zero-on-fix 2>&1 || true",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "cd $CLAUDE_PROJECT_DIR && mypy src/ --ignore-missing-imports --no-error-summary 2>&1 | head -20 || true",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd $CLAUDE_PROJECT_DIR && python -m pytest tests/ --tb=short -q 2>&1 | tail -10 || true",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo $TOOL_INPUT | python -c \"import sys,json; d=json.load(sys.stdin); p=d.get('file_path',''); exit(2 if 'specs/' in p else 0)\" 2>&1 || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
